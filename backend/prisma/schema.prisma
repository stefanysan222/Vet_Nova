generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  VETERINARIO
  ASISTENTE
}

model propietarios {
  id_propietario Int     @id @default(autoincrement())
  nombre         String  @db.VarChar(100)
  telefono       String  @db.VarChar(20)
  direccion      String?
  email          String  @unique @db.VarChar(100)

  mascotas mascotas[]
  facturas facturas[]
}

model mascotas {
  id_mascota Int      @id @default(autoincrement())
  nombre     String   @db.VarChar(100)
  especie    String   @db.VarChar(50)
  raza       String   @db.VarChar(50)
  edad       Int
  peso       Decimal? @db.Decimal(5, 2)

  id_propietario Int

  propietario propietarios @relation(fields: [id_propietario], references: [id_propietario])

  citas              citas[]
  historias_clinicas historias_clinicas?
  facturas           facturas[]
  recordatorios      recordatorios[]
  registro_vacunas   registro_vacunas[]
}

model usuarios {
  id_usuario Int @id @default(autoincrement())

  nombre   String
  email    String @unique
  password String

  rol Rol @default(ASISTENTE)

  createdAt DateTime @default(now())

  citas     citas[]
  consultas consultas[]
}

model citas {
  id_cita Int @id @default(autoincrement())

  fecha  DateTime
  hora   dto.hora
  estado String   @default("pendiente")

  id_mascota Int
  id_usuario Int

  mascotas mascotas @relation(fields: [id_mascota], references: [id_mascota])

  usuarios usuarios @relation(fields: [id_usuario], references: [id_usuario])
}

model historias_clinicas {
  id_historia Int @id @default(autoincrement())

  id_mascota Int @unique

  fecha_creacion DateTime @default(now())

  mascotas mascotas @relation(fields: [id_mascota], references: [id_mascota])

  consultas consultas[]
}

model consultas {
  id_consulta Int @id @default(autoincrement())

  fecha DateTime @default(now())

  motivo      String?
  diagnostico String?
  tratamiento String?

  id_historia Int
  id_usuario  Int

  historias_clinicas historias_clinicas @relation(fields: [id_historia], references: [id_historia])

  usuarios usuarios @relation(fields: [id_usuario], references: [id_usuario])
}

model servicios {
  id_servicio Int @id @default(autoincrement())

  nombre String @db.VarChar(100)

  precio Decimal @db.Decimal(10, 2)

  detalle_servicios detalle_servicios[]
}

model facturas {
  id_factura Int @id @default(autoincrement())

  fecha DateTime @default(now())

  total Decimal @db.Decimal(10, 2)

  id_propietario Int
  id_mascota     Int

  propietarios propietarios @relation(fields: [id_propietario], references: [id_propietario])

  mascotas mascotas @relation(fields: [id_mascota], references: [id_mascota])

  detalle_servicios detalle_servicios[]
  detalle_productos detalle_productos[]
}

model detalle_servicios {
  id_detalle Int @id @default(autoincrement())

  id_factura  Int
  id_servicio Int

  cantidad Int

  precio_unitario Decimal @db.Decimal(10, 2)

  facturas facturas @relation(fields: [id_factura], references: [id_factura])

  servicios servicios @relation(fields: [id_servicio], references: [id_servicio])
}

model productos {
  id_producto Int @id @default(autoincrement())

  nombre String @db.VarChar(100)

  tipo String @db.VarChar(50)

  precio Decimal @db.Decimal(10, 2)

  stock Int

  detalle_productos      detalle_productos[]
  movimientos_inventario movimientos_inventario[]
}

model detalle_productos {
  id_detalle Int @id @default(autoincrement())

  id_factura  Int
  id_producto Int

  cantidad Int

  precio_unitario Decimal @db.Decimal(10, 2)

  facturas facturas @relation(fields: [id_factura], references: [id_factura])

  productos productos @relation(fields: [id_producto], references: [id_producto])
}

model movimientos_inventario {
  id_movimiento Int @id @default(autoincrement())

  tipo String @db.VarChar(20)

  cantidad Int

  fecha DateTime @default(now())

  id_producto Int

  productos productos @relation(fields: [id_producto], references: [id_producto])
}

model vacunas {
  id_vacuna Int @id @default(autoincrement())

  nombre String @db.VarChar(100)

  frecuencia_dias Int

  registro_vacunas registro_vacunas[]
}

model registro_vacunas {
  id_registro Int @id @default(autoincrement())

  fecha DateTime

  proxima_fecha DateTime

  id_mascota Int
  id_vacuna  Int

  mascotas mascotas @relation(fields: [id_mascota], references: [id_mascota])

  vacunas vacunas @relation(fields: [id_vacuna], references: [id_vacuna])
}

model recordatorios {
  id_recordatorio Int @id @default(autoincrement())

  mensaje String

  fecha_recordatorio DateTime

  estado String @default("pendiente")

  id_mascota Int

  mascotas mascotas @relation(fields: [id_mascota], references: [id_mascota])
}
